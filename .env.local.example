# ─────────────────────────────────────────────────────────────────────────────
# Ever Spark Monitoring — environment variables
#
# The app runs fully in DEMO MODE with no env vars (mock data + mock auth).
# Copy this file to `.env.local` and fill in the values to go live.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API in the Supabase dashboard.

# Public — safe to expose to the browser (prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose in client code or git.
# Used by /api/ingest, /api/export, /api/invite to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cron security ─────────────────────────────────────────────────────────────
# Random secret used to authorise calls to /api/cron/device-status.
# Set the same value in your Vercel cron job headers or EC2 curl command.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── Sprint 3 (push notifications) ────────────────────────────────────────────
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@eversparktech.com

# ── Sprint 3 (SMS via Africa's Talking) ──────────────────────────────────────
# AT_API_KEY=your-africas-talking-api-key
# AT_USERNAME=sandbox   # or your production username

# ── Sprint 4 (email reports via Resend) ──────────────────────────────────────
# RESEND_API_KEY=your-resend-api-key
# FROM_EMAIL=reports@eversparktech.com
