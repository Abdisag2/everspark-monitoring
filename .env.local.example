# ─────────────────────────────────────────────────────────────────────────────
# Ever Spark Monitoring — environment
#
# The app runs fully in DEMO MODE with no env vars (mock data + mock Supabase
# client). Set these to connect a real Supabase project.
# Copy to `.env.local` and fill in.
# ─────────────────────────────────────────────────────────────────────────────

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NEVER expose. Used by /api/ingest to write telemetry,
# bypassing RLS for the hardware nodes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
